### Deere Inspect — Example environment variables
# Copy this file to `.env` and fill secrets locally. DO NOT commit `.env`.

# Backend / Database
DATABASE_URL=postgresql+psycopg2://postgres:REPLACE_WITH_PASSWORD@db:5432/deere_inspect
POSTGRES_DB=deere_inspect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password

# Frontend
VITE_API_URL=http://localhost:8000

# Initial Admin (created only on first run when database is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_secure_password

# Optional
API_PREFIX=/api
APP_NAME=Deere Inspect API
SECRET_KEY=replace_with_secret_key_for_auth
